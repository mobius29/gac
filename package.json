{
  "name": "@mobius29/gac",
  "version": "1.0.0",
  "description": "Generate one strong Conventional Commit subject line from git diff",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gac": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run --cache ./.npm-cache",
    "release:check": "pnpm typecheck && pnpm test && pnpm build && pnpm pack:check",
    "prepublishOnly": "pnpm release:check"
  },
  "engines": {
    "node": ">=18.18"
  },
  "keywords": [
    "git",
    "commit",
    "conventional-commits",
    "cli",
    "llm"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.3"
}
